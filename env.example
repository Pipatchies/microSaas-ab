# === Backend ===
SECRET_KEY=<your_secret_key_here>
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# === Database ===
# --- Production (Render.com) ---
# DATABASE_URL takes priority over individual DB_* vars when set.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=

# --- Development (docker-compose) — used when DATABASE_URL is empty ---
DB_ENGINE=django.db.backends.postgresql
DB_NAME=<your_database_name>
DB_USER=<your_db_user>
DB_PASSWORD=<your_db_password>
DB_HOST=postgres
DB_PORT=5432

# === CORS ===
# Comma-separated list of allowed origins added on top of localhost defaults.
# In production, set this to your Vercel frontend URL.
# Example: CORS_ALLOWED_ORIGINS=https://your-app.vercel.app
CORS_ALLOWED_ORIGINS=

# === Ports (docker-compose) ===
API_PORT=8800
CLIENT_PORT=3000

# === Frontend ===
NEXT_PUBLIC_API_URL=http://localhost:8800
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=<your_mapbox_access_token>
# JWT settings
JWT_SECRET_KEY=<your_jwt_secret_key>
